<?xml version="1.0" encoding="utf-8"?>
<!-- Floating overlay window: always-visible status bar + fade-in subtitle -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Subtitle area with small status dot at top-left corner -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Original language text (small) — shown during streaming/translation -->
            <TextView
                android:id="@+id/tvOriginal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#99000000"
                android:gravity="center"
                android:maxLines="2"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:text=""
                android:textColor="#AAFFFFFF"
                android:textSize="12sp"
                android:visibility="gone" />

            <!-- Main subtitle (Korean translation) -->
            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/subtitle_bg"
                android:gravity="center"
                android:lineSpacingMultiplier="1.25"
                android:maxLines="3"
                android:paddingHorizontal="16dp"
                android:paddingVertical="10dp"
                android:text=""
                android:textColor="@color/subtitle_text"
                android:textSize="20sp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Small status indicator dot (6dp) — always visible -->
        <View
            android:id="@+id/statusDot"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_gravity="top|start"
            android:layout_margin="4dp"
            android:background="@drawable/status_dot" />

    </FrameLayout>

    <!-- Debug info row: ASR raw text / RMS / language — visible during diagnosis -->
    <TextView
        android:id="@+id/tvDebug"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"
        android:background="#AA000000"
        android:fontFamily="monospace"
        android:gravity="start"
        android:maxLines="6"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:text=""
        android:textColor="#DDFFFFFF"
        android:textSize="10sp"
        android:visibility="gone" />

</LinearLayout>
